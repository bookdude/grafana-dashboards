                    "queryType": "timeSeries",
                    "rawSql": "SELECT toStartOfHour(ts) AS time, if(sum(inventory)=0,0,sum(impressions)/sum(inventory)) AS impr_per_inv FROM podcast_splits WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
