                    "rawSql": "SELECT x, y\nFROM default.media_ai_pdp\nWHERE run_time = (SELECT max(run_time) FROM default.media_ai_pdp)\n  AND target = '${target}'\n  AND var = '${pdp_var}'\nORDER BY x",
