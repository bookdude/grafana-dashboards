            "targets": [
                {
                    "datasource": {
                        "type": "grafana-clickhouse-datasource",
                        "uid": "aep99bsdau1a8f"
                    },
                    "editorType": "sql",
                    "format": 1,
                    "meta": {
                        "builderOptions": {
                            "columns": [],
                            "database": "",
                            "limit": 1000,
                            "mode": "list",
                            "queryType": "table",
                            "table": ""
                        }
                    },
                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "/* Step 1: assign each row to an hour bucket */\nWITH samples AS (\n  SELECT\n    host,\n    toStartOfHour(ts)      AS hour,\n    ts,\n    node_network_rx_bytes\n  FROM node_exporter_metrics\n  WHERE ts >= now() - INTERVAL 24 HOUR  -- choose how far back you want to visualise\n),\n\n/* Step 2: rank samples per host per hour, newest first */\nranked AS (\n  SELECT\n    host,\n    hour,\n    ts,\n    node_network_rx_bytes,\n    row_number() OVER (\n      PARTITION BY host, hour\n      ORDER BY ts DESC\n    ) AS rn\n  FROM samples\n),\n\n/* Step 3: compute the byte\u2011difference and time\u2011difference for the two most recent samples per host per hour */\npaired AS (\n  SELECT\n    curr.hour,\n    curr.host,\n    curr.node_network_rx_bytes - prev.node_network_rx_bytes AS rx_bytes_diff,\n    dateDiff('second', prev.ts, curr.ts) AS duration_sec\n  FROM ranked AS curr\n  JOIN ranked AS prev\n    ON curr.host = prev.host\n   AND curr.hour = prev.hour\n  WHERE curr.rn = 1\n    AND prev.rn = 2\n    AND curr.node_network_rx_bytes >= prev.node_network_rx_bytes\n),\n\n/* Step 4: aggregate across hosts for each hour and compute Mbps */\nagg AS (\n  SELECT\n    hour,\n    sum(rx_bytes_diff)        AS sum_rx_bytes,\n    sum(duration_sec)         AS sum_duration,\n    count()                   AS n_pairs\n  FROM paired\n  GROUP BY hour\n)\n\nSELECT\n  hour AS ts,\n  round(\n    (sum_rx_bytes * 8) / 1024 / 1024 /\n    (sum_duration / n_pairs),\n    2\n  ) AS total_rx_mbps\nFROM agg\nORDER BY ts ASC;\n",
                    "refId": "A"
                }
            ],
            "title": "TX Aggregate Bandwidth",
            "type": "timeseries"
        },
