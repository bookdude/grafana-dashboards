                    "rawSql": "WITH base AS (SELECT toStartOfHour(ts) AS time, if(sum(inventory)=0,0,sum(impressions)/sum(inventory)) AS impr_per_inv FROM podcast_splits WHERE $__timeFilter(ts) GROUP BY time ORDER BY time) SELECT time, avg(impr_per_inv) OVER (ORDER BY time ROWS BETWEEN 23 PRECEDING AND CURRENT ROW) AS imprpi_roll_24h FROM base ORDER BY time",
