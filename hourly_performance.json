                    },
                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH\n  cutoff AS (\n    SELECT (toStartOfHour(now()) - INTERVAL 2 HOUR) AS cut\n  ),\n  per_hour AS (\n    SELECT\n      toStartOfHour(timestamp) AS time,\n      sum(Impressions) AS imps,\n      sum(Requests)    AS reqs\n    FROM default.`26_ss_dist_reporting`\n    WHERE timestamp >= (SELECT cut FROM cutoff) - INTERVAL 24 HOUR\n      AND timestamp <  (SELECT cut FROM cutoff)\n    GROUP BY time\n  ),\n  per_hour_win_volume AS (\n    SELECT\n      time,\n      imps,\n      reqs,\n      imps / nullIf(reqs, 0) AS winrate,\n      imps * (imps / nullIf(reqs, 0)) AS weighted_win\n    FROM per_hour\n  )\nSELECT\n  time,\n  weighted_win / sum(weighted_win) OVER () * 100 AS winrate_share_pct\nFROM per_hour_win_volume\nORDER BY time;\n",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "grafana-clickhouse-datasource",
