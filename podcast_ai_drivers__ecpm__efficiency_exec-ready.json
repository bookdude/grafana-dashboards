            "pluginVersion": "12.3.1",
            "targets": [
                {
                    "editorType": "sql",
                    "format": 1,
                    "meta": {},
                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH diffs AS (\n  SELECT\n    target,\n    var,\n    x,\n    y,\n    y - lag(y) OVER (PARTITION BY target, var ORDER BY x) AS dy\n  FROM podcast_ai_driver_pdp\n  WHERE run_time = parseDateTimeBestEffort('${run_time}')\n),\nagg AS (\n  SELECT\n    target,\n    var,\n    any(y) AS baseline_y,\n    max(y) AS max_y,\n    minIf(x, dy < 0.01) AS saturation_x\n  FROM diffs\n  GROUP BY target, var\n)\nSELECT\n  CASE\n    WHEN target = 'ecpm' AND var = 'hod'\n      THEN 'Time-of-Day Bid Sensitivity'\n    WHEN target = 'ecpm' AND var = 'log_inv'\n      THEN 'Inventory Saturation Effect'\n    WHEN target = 'impr_per_inv' AND var = 'hod'\n      THEN 'Inventory Utilization by Time'\n    WHEN target = 'impr_per_inv' AND var = 'log_inv'\n      THEN 'Inventory Saturation Risk'\n    ELSE concat(target, ' / ', var)\n  END AS Driver,\n  \n  round(baseline_y, 2)                  AS Baseline_eCPM,\n  round(max_y, 2)                       AS Max_eCPM,\n  round((max_y - baseline_y), 3)        AS Absolute_Gain,\n  round((max_y - baseline_y) / baseline_y * 100, 1) AS Gain_pct,\n  round(saturation_x, 1)                AS Saturation_Point,\n  if(\n    (max_y - baseline_y) / baseline_y < 0.03,\n    'Low impact \u2013 cap early',\n    'Meaningful gain \u2013 allow expansion'\n  ) AS Recommendation\nFROM agg\nORDER BY Gain_pct DESC;\n",
                    "refId": "A"
                }
            ],
            "title": "Shape curves (PDP) \u2014 saturation & time effects",
            "type": "table"
        },
