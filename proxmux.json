                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH (SELECT max(ts) FROM default.node_exporter_metrics) AS t_end\nSELECT\n  host,\n  round((rx_bytes_diff * 8.0 /1025 /1024 ) / duration_sec, 2) AS rx_mbps\nFROM\n(\n  SELECT\n    curr.host AS host,\n    (curr.node_network_rx_bytes - prev.node_network_rx_bytes) AS rx_bytes_diff,\n    dateDiff('second', prev.ts, curr.ts) AS duration_sec\n  FROM\n  (\n    SELECT\n      host, ts, node_network_rx_bytes,\n      row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n    FROM default.node_exporter_metrics\n    WHERE ts <= t_end\n  ) AS curr\n  INNER JOIN\n  (\n    SELECT\n      host, ts, node_network_rx_bytes,\n      row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n    FROM default.node_exporter_metrics\n    WHERE ts <= t_end\n  ) AS prev\n    ON curr.host = prev.host\n   AND curr.rn = 1\n   AND prev.rn = 2\n  WHERE curr.ts >= t_end - INTERVAL 30 MINUTE          -- host detected recently\n    AND dateDiff('second', prev.ts, curr.ts) > 0\n    AND dateDiff('second', prev.ts, curr.ts) <= 1800   -- last two samples within 30 min\n    AND curr.node_network_rx_bytes >= prev.node_network_rx_bytes\n)\nORDER BY rx_mbps DESC\nLIMIT 200;\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux RX  Traffic",
            "type": "bargauge"
