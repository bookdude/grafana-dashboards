                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH latest AS (\n  SELECT\n    host,\n    argMax(node_cpu_user_seconds, ts)   AS user_sec,\n    argMax(node_cpu_system_seconds, ts) AS system_sec,\n    argMax(node_cpu_idle_seconds, ts)   AS idle_sec\n  FROM node_exporter_metrics\n  -- optional: restrict to last 30\u202fminutes if desired\n  -- WHERE ts >= now() - INTERVAL 30 MINUTE\n  GROUP BY host\n)\nSELECT\n  host,\n  round(\n    (user_sec + system_sec) /\n    (user_sec + system_sec + idle_sec) * 100,\n    2\n  ) AS cpu_usage_percent\nFROM latest\nORDER BY cpu_usage_percent DESC\nLIMIT 300;\n",
                    "refId": "B"
                }
            ],
