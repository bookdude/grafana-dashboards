                    "queryType": "table",
                    "rawSql": "/* Latest hour snapshot - ranked view */\nWITH\n  (SELECT max(hour_bucket) FROM default.dist_perf_hourly) AS latest_hour\nSELECT\n  hour_bucket,\n  Dist,\n  Requests,\n  Impressions,\n  WinRate,\n  rank_best_wr,\n  rank_worst_wr\nFROM default.dist_perf_hourly_ranked\nWHERE hour_bucket = latest_hour\n  AND (\n    ('[[rank_type]]' = 'top' AND rank_best_wr <= toInt32('[[rank_n]]')) OR\n    ('[[rank_type]]' = 'bottom' AND rank_worst_wr <= toInt32('[[rank_n]]'))\n  )\nORDER BY\n  if('[[rank_type]]' = 'top', rank_best_wr, rank_worst_wr) ASC,\n  Impressions DESC\nLIMIT 200\n",
