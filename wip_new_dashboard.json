                    "queryType": "table",
                    "rawSql": "/* High impact failures: big volume, bad winrate (24h) */\nWITH\n  (SELECT max(hour_bucket) FROM default.dist_perf_hourly) AS h,\n  h - INTERVAL 24 HOUR AS w24_start,\n  (SELECT gate_impressions FROM default.dist_perf_gate ORDER BY computed_at DESC LIMIT 1) AS gate_imp\nSELECT\n  Dist,\n  sum(Impressions) AS imp_24h,\n  sum(Requests)    AS req_24h,\n  (imp_24h / nullIf(req_24h, 0)) AS wr_24h\nFROM default.dist_perf_hourly\nWHERE hour_bucket >= w24_start AND hour_bucket <= h\nGROUP BY Dist\nHAVING imp_24h >= gate_imp\nORDER BY wr_24h ASC, imp_24h DESC\nLIMIT toInt32('[[rank_n]]')\n",
                    "refId": "A"
                }
            ],
            "title": "High impact failures: low WinRate and high Impressions (24h)",
            "type": "barchart"
