                    "rawSql": "SELECT\n  publisher,\n  hod,\n  avg_ecpm,\n  avg_wr,\n  avg_eff,\n  avg_fill,\n  requests,\n  inventory,\n  impressions\nFROM default.media_ai_structure\nWHERE run_time = (SELECT max(run_time) FROM default.media_ai_structure)\n  AND match(publisher, '${publisher}')\nORDER BY\n  if('${target}'='ecpm', avg_ecpm,\n     if('${target}'='win_rate', avg_wr, avg_eff)) DESC\nLIMIT 200",
