                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH\n  t_end AS (SELECT max(ts) AS t FROM default.node_exporter_metrics),\n\n  samples AS (\n    SELECT\n      host,\n      ts,\n      node_network_rx_bytes,\n      node_network_tx_bytes,\n      row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n    FROM default.node_exporter_metrics\n    WHERE ts >= (SELECT t FROM t_end) - INTERVAL 30 MINUTE\n      AND ts <= (SELECT t FROM t_end)\n  ),\n\n  deltas AS (\n    SELECT\n      curr.host AS host,\n      (curr.node_network_rx_bytes - prev.node_network_rx_bytes) AS rx_diff,\n      (curr.node_network_tx_bytes - prev.node_network_tx_bytes) AS tx_diff,\n      dateDiff('second', prev.ts, curr.ts) AS duration_sec\n    FROM samples AS curr\n    INNER JOIN samples AS prev\n      ON curr.host = prev.host\n     AND curr.rn = 1\n     AND prev.rn = 2\n    WHERE\n      curr.node_network_rx_bytes >= prev.node_network_rx_bytes\n      AND curr.node_network_tx_bytes >= prev.node_network_tx_bytes\n      AND dateDiff('second', prev.ts, curr.ts) > 0\n  )\n\nSELECT\n  host,\n  round(rx_diff / nullIf(tx_diff, 0), 2) AS rx_tx_ratio\nFROM deltas\nORDER BY rx_tx_ratio DESC\nLIMIT 200;\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux  Traffic Ratios",
            "type": "bargauge"
