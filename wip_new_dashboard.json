                    "queryType": "table",
                    "rawSql": "/* Drilldown: single Dist WinRate */\nWITH\n  parseDateTimeBestEffort('${__from:date:iso}') AS t_from,\n  parseDateTimeBestEffort('${__to:date:iso}')   AS t_to\nSELECT\n  hour_bucket AS time,\n  Dist AS metric,\n  WinRate AS value\nFROM default.dist_perf_hourly\nWHERE hour_bucket >= t_from AND hour_bucket <= t_to\n  AND Dist = '[[dist_one]]'\nORDER BY time\n",
                    "refId": "A"
                }
            ],
            "title": "Drilldown: single Dist WinRate",
