                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "SELECT ip, loss\nFROM (\n    SELECT\n        ip,\n        loss,\n        row_number() OVER (PARTITION BY ip ORDER BY timestamp DESC) AS rn\n    FROM default.ping_results\n)\nWHERE rn = 1\n  AND loss >= 5\nORDER BY ip;\n",
