{
  "title": "VCASA System Status",
  "uid": "vcasa-system-status",
  "description": "Real-time up/down status for all VCASA units. Universe = all units observed YTD. Online = active in the most recent data hour. Sorted by reliability (Up %).",
  "tags": [
    "vcasa",
    "updown",
    "monitoring",
    "clickhouse"
  ],
  "timezone": "browser",
  "graphTooltip": 1,
  "refresh": "5m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Online",
      "description": "VCASA units with activity in the most recent data hour",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aep99bsdau1a8f"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "SELECT countDistinct(v.vcasa_name) AS online\nFROM default.`26_ss_dist_reporting` r\nJOIN default.v_vcasa_to_dist v ON r.Dist = v.dist\nWHERE r.timestamp >= toStartOfHour((SELECT max(timestamp) FROM default.`26_ss_dist_reporting`))\n  AND r.Dist NOT LIKE 'generated%'",
          "format": 1,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Offline",
      "description": "YTD units with no activity in the most recent data hour",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aep99bsdau1a8f"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "WITH\n  latest_hour AS (\n    SELECT toStartOfHour(max(timestamp)) AS t FROM default.`26_ss_dist_reporting`\n  ),\n  ytd_names AS (\n    SELECT DISTINCT v.vcasa_name\n    FROM default.`26_ss_dist_reporting` r\n    JOIN default.v_vcasa_to_dist v ON r.Dist = v.dist\n    WHERE r.timestamp >= toStartOfYear(today())\n      AND r.Dist NOT LIKE 'generated%'\n  ),\n  online_names AS (\n    SELECT DISTINCT v.vcasa_name\n    FROM default.`26_ss_dist_reporting` r\n    JOIN default.v_vcasa_to_dist v ON r.Dist = v.dist\n    WHERE r.timestamp >= (SELECT t FROM latest_hour)\n      AND r.Dist NOT LIKE 'generated%'\n  )\nSELECT countIf(o.vcasa_name = '') AS offline\nFROM ytd_names y\nLEFT JOIN online_names o ON y.vcasa_name = o.vcasa_name",
          "format": 1,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total YTD Units",
      "description": "Distinct VCASA units observed since January 1st",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aep99bsdau1a8f"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "SELECT countDistinct(v.vcasa_name) AS total_ytd\nFROM default.`26_ss_dist_reporting` r\nJOIN default.v_vcasa_to_dist v ON r.Dist = v.dist\nWHERE r.timestamp >= toStartOfYear(today())\n  AND r.Dist NOT LIKE 'generated%'",
          "format": 1,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latest Data Hour",
      "description": "Timestamp of the most recent data ingestion \u2014 Online/Offline status is relative to this hour",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aep99bsdau1a8f"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "auto",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "SELECT toUnixTimestamp(toStartOfHour(max(timestamp))) * 1000 AS latest_hour\nFROM default.`26_ss_dist_reporting`",
          "format": 1,
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "VCASA Online Count Over Time",
      "description": "Distinct VCASA units active per hour. Responds to the dashboard time range picker.",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aep99bsdau1a8f"
      },
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean", "last"]}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "barAlignment": 0
          },
          "color": {"fixedColor": "green", "mode": "fixed"},
          "unit": "short",
          "displayName": "Online"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "SELECT toStartOfHour(r.timestamp) AS time, countDistinct(v.vcasa_name) AS online_count FROM default.`26_ss_dist_reporting` r JOIN default.v_vcasa_to_dist v ON r.Dist = v.dist WHERE $__timeFilter(r.timestamp) AND r.Dist NOT LIKE 'generated%' GROUP BY time ORDER BY time",
          "format": 0,
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Fleet Network Health Over Time",
      "description": "Fleet-wide average RTT (ms, left axis) and packet loss % (right axis) from 10-minute ping cycles. Responds to the dashboard time range picker.",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "aep99bsdau1a8f"
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"]}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "axisPlacement": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "avg_rtt_ms"},
            "properties": [
              {"id": "unit", "value": "ms"},
              {"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}},
              {"id": "displayName", "value": "Avg RTT ms"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "avg_loss_pct"},
            "properties": [
              {"id": "custom.axisPlacement", "value": "right"},
              {"id": "unit", "value": "percent"},
              {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}},
              {"id": "displayName", "value": "Avg Loss %"}
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "SELECT toStartOfInterval(timestamp, INTERVAL 10 MINUTE) AS time, avgIf(rtt_avg, tx > 0) AS avg_rtt_ms, avgIf(loss, tx > 0) * 100 AS avg_loss_pct FROM default.ping_results WHERE $__timeFilter(timestamp) AND tx > 0 GROUP BY time ORDER BY time",
          "format": 0,
          "refId": "A"
        }
      ]
    },
