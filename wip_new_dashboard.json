                    "queryType": "table",
                    "rawSql": "/* Biggest movers: 24h winrate vs prior 72h baseline */\nWITH\n  (SELECT max(hour_bucket) FROM default.dist_perf_hourly) AS h,\n  h - INTERVAL 24 HOUR AS w24_start,\n  h - INTERVAL 96 HOUR AS w96_start,          -- 24h + prior 72h\n  h - INTERVAL 24 HOUR AS base_end,\n  (SELECT gate_impressions FROM default.dist_perf_gate ORDER BY computed_at DESC LIMIT 1) AS gate_imp\nSELECT\n  Dist,\n  sumIf(Impressions, hour_bucket >= w24_start AND hour_bucket <= h) AS imp_24h,\n  sumIf(Requests,    hour_bucket >= w24_start AND hour_bucket <= h) AS req_24h,\n  (imp_24h / nullIf(req_24h, 0)) AS wr_24h,\n\n  sumIf(Impressions, hour_bucket >= w96_start AND hour_bucket < base_end) AS imp_base72h,\n  sumIf(Requests,    hour_bucket >= w96_start AND hour_bucket < base_end) AS req_base72h,\n  (imp_base72h / nullIf(req_base72h, 0)) AS wr_base72h,\n\n  (wr_24h - wr_base72h) AS wr_delta\nFROM default.dist_perf_hourly\nWHERE hour_bucket >= w96_start AND hour_bucket <= h\nGROUP BY Dist\nHAVING imp_24h >= gate_imp AND imp_base72h >= gate_imp\nORDER BY\n  if('[[rank_type]]'='top', wr_delta, -wr_delta) DESC,\n  imp_24h DESC\nLIMIT toInt32('[[rank_n]]')\n",
                    "refId": "A"
                }
            ],
            "title": "Biggest movers: 24h winrate vs prior 72h baseline",
            "type": "table"
        },
