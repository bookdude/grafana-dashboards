                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "/* Top 25 by impact-weighted winrate (60d), % only */\n\nWITH\n  now() AS t_now,\n  toStartOfMonth(t_now) AS t_mtd,\n  t_now - INTERVAL 30 DAY AS t_30d,\n  t_now - INTERVAL 60 DAY AS t_60d,\n\n  top25 AS\n  (\n    SELECT Dist\n    FROM\n    (\n      SELECT\n        Dist,\n        sumIf(Impressions, hour_bucket >= t_60d) AS imp_60d,\n        sumIf(Requests,    hour_bucket >= t_60d) AS req_60d,\n        (imp_60d / nullIf(req_60d,0)) AS wr_60d\n      FROM default.dist_perf_hourly\n      GROUP BY Dist\n      HAVING imp_60d >= 5000   -- hard floor, adjustable\n      ORDER BY (wr_60d * log10(imp_60d + 10)) DESC\n      LIMIT 25\n    )\n  )\n\nSELECT\n  Dist,\n\n  (sumIf(Impressions, hour_bucket >= t_mtd) /\n   nullIf(sumIf(Requests, hour_bucket >= t_mtd),0)) AS wr_mtd,\n\n  (sumIf(Impressions, hour_bucket >= t_30d) /\n   nullIf(sumIf(Requests, hour_bucket >= t_30d),0)) AS wr_30d,\n\n  (sumIf(Impressions, hour_bucket >= t_60d) /\n   nullIf(sumIf(Requests, hour_bucket >= t_60d),0)) AS wr_60d,\n\n  (sum(Impressions) / nullIf(sum(Requests),0)) AS wr_all\n\nFROM default.dist_perf_hourly\nWHERE Dist IN top25\nGROUP BY Dist\nORDER BY wr_60d DESC\n",
                    "refId": "A"
                }
            ],
            "title": "New panel",
            "type": "barchart"
        },
