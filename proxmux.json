                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH diffs AS (\n  SELECT\n    host,\n    maxIf(ts, rn = 1) AS ts_new,\n    maxIf(ts, rn = 2) AS ts_old,\n    maxIf(node_network_receive_drop_total, rn = 1) AS rx_new,\n    maxIf(node_network_receive_drop_total, rn = 2) AS rx_old,\n    maxIf(node_network_transmit_drop_total, rn = 1) AS tx_new,\n    maxIf(node_network_transmit_drop_total, rn = 2) AS tx_old\n  FROM (\n    SELECT\n      host,\n      ts,\n      node_network_receive_drop_total,\n      node_network_transmit_drop_total,\n      row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n    FROM node_exporter_metrics\n    WHERE ts >= now() - INTERVAL 30 MINUTE\n      -- AND host LIKE 'prox%'  -- re-enable if you actually have prox* hosts\n  )\n  GROUP BY host\n  HAVING ts_old IS NOT NULL AND ts_new > ts_old\n),\nagg AS (\n  SELECT\n    sum(rx_new - rx_old) AS sum_rx_diff,\n    sum(tx_new - tx_old) AS sum_tx_diff,\n    sum(toUnixTimestamp(ts_new) - toUnixTimestamp(ts_old)) AS sum_dt\n  FROM diffs\n)\nSELECT\n  if(\n    sum_dt = 0,\n    0,\n    round(sum_rx_diff / sum_dt, 4)\n  ) AS total_rx_drops_per_sec,\n  if(\n    sum_dt = 0,\n    0,\n    round(sum_tx_diff / sum_dt, 4)\n  ) AS total_tx_drops_per_sec\nFROM agg;\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux  Network Drops",
            "type": "gauge"
        },
