                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH raw AS (\n  SELECT\n    host,\n    ts,\n    node_network_rx_bytes\n  FROM default.node_exporter_metrics\n  WHERE ts >= (SELECT max(ts) FROM default.node_exporter_metrics) - INTERVAL 30 MINUTE\n),\nranked AS (\n  SELECT\n    host,\n    ts,\n    node_network_rx_bytes,\n    row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n  FROM raw\n),\npaired AS (\n  SELECT\n    curr.host AS host,\n    (curr.node_network_rx_bytes - prev.node_network_rx_bytes) AS rx_bytes_diff,\n    dateDiff('second', prev.ts, curr.ts) AS duration_sec\n  FROM ranked AS curr\n  INNER JOIN ranked AS prev\n    ON curr.host = prev.host\n   AND curr.rn = 1\n   AND prev.rn = 2\n  WHERE curr.node_network_rx_bytes >= prev.node_network_rx_bytes\n    AND dateDiff('second', prev.ts, curr.ts) > 0\n)\nSELECT\n  round( (sum(rx_bytes_diff) * 8.0) / nullIf(sum(duration_sec), 0), 2 ) AS total_rx_mbps\nFROM paired;\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux RX  Traffic",
            "type": "gauge"
        },
