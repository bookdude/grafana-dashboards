                {
                    "editorType": "sql",
                    "format": 0,
                    "queryType": "timeSeries",
                    "rawSql": "SELECT toStartOfHour(ts) AS time, avg(`eCPM (USD)`) AS ecpm FROM podcast_splits WHERE $__timeFilter(ts) GROUP BY time ORDER BY time",
                    "refId": "A"
                },
                {
                    "editorType": "sql",
                    "format": 0,
                    "queryType": "timeSeries",
                    "rawSql": "WITH base AS (SELECT toStartOfHour(ts) AS time, avg(`eCPM (USD)`) AS ecpm FROM podcast_splits WHERE $__timeFilter(ts) GROUP BY time ORDER BY time) SELECT time, avg(ecpm) OVER (ORDER BY time ROWS BETWEEN 23 PRECEDING AND CURRENT ROW) AS ecpm_roll_24h FROM base ORDER BY time",
                    "refId": "B"
                },
                {
                    "editorType": "sql",
                    "format": 0,
                    "queryType": "timeSeries",
                    "rawSql": "SELECT toStartOfHour(ts) AS time, avg(`eCPM (USD)`) AS ecpm_same_hour_yday FROM podcast_splits WHERE $__timeFilter(ts - INTERVAL 24 HOUR) GROUP BY time ORDER BY time",
                    "refId": "C"
                }
            ],
            "title": "eCPM (hourly) + 24h rolling + same-hour-yesterday",
            "type": "timeseries"
