                    },
                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH\n  t_end AS (SELECT max(ts) AS t FROM default.node_exporter_metrics),\n  raw AS (\n    SELECT\n      host,\n      ts,\n      node_network_receive_drop_total  AS rx_drop,\n      node_network_transmit_drop_total AS tx_drop,\n      row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n    FROM default.node_exporter_metrics\n    WHERE ts >= (SELECT t FROM t_end) - INTERVAL 30 MINUTE\n      AND ts <= (SELECT t FROM t_end)\n  ),\n  paired AS (\n    SELECT\n      host,\n      maxIf(ts, rn = 1) AS ts_new,\n      maxIf(ts, rn = 2) AS ts_old,\n      maxIf(rx_drop, rn = 1) AS rx_new,\n      maxIf(rx_drop, rn = 2) AS rx_old,\n      maxIf(tx_drop, rn = 1) AS tx_new,\n      maxIf(tx_drop, rn = 2) AS tx_old\n    FROM raw\n    GROUP BY host\n  )\nSELECT\n  host,\n  round(greatest(rx_new - rx_old, 0) / nullIf(dateDiff('second', ts_old, ts_new), 0), 6) AS rx_drops_per_sec,\n  round(greatest(tx_new - tx_old, 0) / nullIf(dateDiff('second', ts_old, ts_new), 0), 6) AS tx_drops_per_sec\nFROM paired\nWHERE ts_old IS NOT NULL\nORDER BY rx_drops_per_sec DESC\nLIMIT 200;\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux  Network Drops",
            "type": "bargauge"
        }
