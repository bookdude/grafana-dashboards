        {
            "datasource": {
                "type": "grafana-clickhouse-datasource",
                "uid": "${DS_CLICKHOUSE}"
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 17
            },
            "id": 14,
            "options": {
                "cellHeight": "sm",
                "showHeader": true
            },
            "targets": [
                {
                    "editorType": "sql",
                    "format": 1,
                    "queryType": "table",
                    "rawSql": "WITH base AS (\n  SELECT\n    publisher,\n    hod,\n    avg_ecpm,\n    avg_wr,\n    avg_eff,\n    avg_fill,\n    requests,\n    inventory,\n    impressions,\n    if('${target}'='ecpm', avg_ecpm, if('${target}'='win_rate', avg_wr, avg_eff)) AS kpi\n  FROM default.media_ai_structure\n  WHERE run_time = (SELECT max(run_time) FROM default.media_ai_structure)\n    AND match(publisher, '${publisher}')\n), ranked AS (\n  SELECT\n    *,\n    row_number() OVER (PARTITION BY publisher ORDER BY kpi DESC) AS rn_best,\n    row_number() OVER (PARTITION BY publisher ORDER BY kpi ASC)  AS rn_worst\n  FROM base\n)\nSELECT\n  publisher,\n  groupArrayIf(hod, rn_best <= 3) AS best_hours,\n  groupArrayIf(hod, rn_worst <= 3) AS worst_hours\nFROM ranked\nGROUP BY publisher\nORDER BY publisher",
                    "refId": "A"
                }
            ],
            "title": "Best vs worst hours per publisher (action list)",
            "type": "table"
        }
    ],
