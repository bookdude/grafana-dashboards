                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH (SELECT max(ts) FROM default.node_exporter_metrics) AS t_end\nSELECT\n  round(avg(util) * 100, 2) AS cpu_average\nFROM\n(\n  SELECT\n    (sys_d + user_d) / nullIf(idle_d + sys_d + user_d, 0) AS util\n  FROM\n  (\n    SELECT\n      host,\n      count() AS samples,\n      (argMax(node_cpu_idle_seconds, ts)   - argMin(node_cpu_idle_seconds, ts))   AS idle_d,\n      (argMax(node_cpu_system_seconds, ts) - argMin(node_cpu_system_seconds, ts)) AS sys_d,\n      (argMax(node_cpu_user_seconds, ts)   - argMin(node_cpu_user_seconds, ts))   AS user_d\n    FROM default.node_exporter_metrics\n    WHERE ts >= t_end - INTERVAL 10 MINUTE\n      AND ts <= t_end\n    GROUP BY host\n  )\n  WHERE samples >= 2\n    AND (idle_d + sys_d + user_d) > 0\n);\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux CPU",
            "type": "gauge"
        },
