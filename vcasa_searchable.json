                    },
                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "SELECT\n    v.Name,\n    v.FullDIST as DIST,\n    v.postal,\n    v.city,\n    v.state,\n    max(r.timestamp) AS last_seen,\n    sum(r.Requests) AS total_requests,\n    sum(r.Impressions) AS total_impressions,\n    sum(r.Impressions) / nullIf(sum(r.Requests), 0) AS win_rate\nFROM default.Vcasa_to_info AS v\nLEFT JOIN default.`25_ss_dist_reporting` AS r\n    ON v.Dist = r.Dist\nWHERE $__timeFilter(r.timestamp)\nGROUP BY\n    v.Name,\n    v.Dist,\n    v.FullDIST,\n    v.postal,\n    v.city,\n    v.state\n",
                    "refId": "A"
                }
            ],
            "title": "Vcasa Performance Time Series",
