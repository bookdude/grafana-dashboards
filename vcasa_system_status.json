            "uid": "aep99bsdau1a8f"
          },
          "rawSql": "WITH\n  latest_hour AS (\n    SELECT toStartOfHour(max(timestamp)) AS t FROM default.`26_ss_dist_reporting`\n  ),\n  ytd AS (\n    SELECT\n      v.vcasa_name,\n      any(v.ip)                                         AS ip,\n      any(v.dist)                                       AS dist,\n      any(v.city)                                       AS city,\n      any(v.state)                                      AS state,\n      any(v.provider)                                   AS provider,\n      max(r.timestamp)                                  AS last_seen,\n      countDistinct(toStartOfHour(r.timestamp))         AS up_hours\n    FROM default.`26_ss_dist_reporting` r\n    JOIN default.v_vcasa_to_dist v ON r.Dist = v.dist\n    WHERE r.timestamp >= toStartOfYear(today())\n      AND r.Dist NOT LIKE 'generated%'\n    GROUP BY v.vcasa_name\n  ),\n  online AS (\n    SELECT DISTINCT v.vcasa_name\n    FROM default.`26_ss_dist_reporting` r\n    JOIN default.v_vcasa_to_dist v ON r.Dist = v.dist\n    WHERE r.timestamp >= (SELECT t FROM latest_hour)\n      AND r.Dist NOT LIKE 'generated%'\n  ),\n  latest_ping AS (\n    SELECT ip,\n      avgIf(loss,    tx > 0) AS loss_pct,\n      avgIf(rtt_avg, tx > 0) AS rtt_ms,\n      round(avg(rx), 0)      AS rx\n    FROM default.ping_results\n    WHERE timestamp >= now() - INTERVAL 15 MINUTE\n      AND tx > 0\n    GROUP BY ip\n  ),\n  ping_by_vcasa AS (\n    SELECT v.vcasa_name,\n      round(avg(p.loss_pct), 1) AS loss_pct,\n      round(avg(p.rtt_ms),   1) AS rtt_ms,\n      round(avg(p.rx),       0) AS rx\n    FROM default.v_vcasa_to_dist v\n    JOIN latest_ping p ON v.ip = p.ip\n    GROUP BY v.vcasa_name\n  ),\n  net_by_vcasa AS (\n    SELECT v.vcasa_name,\n      round(avg(n.rx_kbps) / 1024, 2) AS rx_mbps\n    FROM default.view_network_kbps_by_host n\n    JOIN default.v_vcasa_to_dist v ON n.host = v.ip\n    GROUP BY v.vcasa_name\n  ),\n  rx_now_cte AS (\n    SELECT v.vcasa_name,\n      round(\n        toFloat64(max(n.node_network_rx_bytes) - min(n.node_network_rx_bytes)) * 8 /\n        greatest(toUnixTimestamp(max(n.ts)) - toUnixTimestamp(min(n.ts)), 1) / 1000 / 1024, 5\n      ) AS rx_now\n    FROM default.node_exporter_metrics n\n    JOIN default.v_vcasa_to_dist v ON n.host = v.ip\n    WHERE n.ts >= now() - INTERVAL 1 HOUR\n    GROUP BY v.vcasa_name\n    HAVING count() >= 2\n  ),\n  rx_then_cte AS (\n    SELECT v.vcasa_name,\n      round(\n        toFloat64(max(n.node_network_rx_bytes) - min(n.node_network_rx_bytes)) * 8 /\n        greatest(toUnixTimestamp(max(n.ts)) - toUnixTimestamp(min(n.ts)), 1) / 1000 / 1024, 5\n      ) AS rx_then\n    FROM default.node_exporter_metrics n\n    JOIN default.v_vcasa_to_dist v ON n.host = v.ip\n    WHERE n.ts >= now() - INTERVAL 5 HOUR AND n.ts < now() - INTERVAL 4 HOUR\n    GROUP BY v.vcasa_name\n    HAVING count() >= 2\n  )\nSELECT\n  if(o.vcasa_name != '', 1, 0)                                                     AS \"Status\",\n  y.vcasa_name                                                                     AS \"VCASA\",\n  if(startsWith(y.dist, 'w_'), substring(y.dist, 3), y.dist)                      AS \"Dist\",\n  y.city                                                                           AS \"City\",\n  y.state                                                                          AS \"State\",\n  y.ip                                                                             AS \"IP\",\n  round(y.up_hours * 100.0 / dateDiff('hour', toStartOfYear(today()), now()), 1)  AS \"Up %\",\n  y.up_hours                                                                       AS \"Up Hours\",\n  pg.loss_pct                                                                      AS \"Loss %\",\n  pg.rtt_ms                                                                        AS \"RTT ms\",\n  pg.rx                                                                            AS \"Ping RX\",\n  nk.rx_mbps                                                                       AS \"RX MB/s\",\n  if(rn.rx_now > 0 AND rt.rx_then > 0,\n     round((rn.rx_now - rt.rx_then) / nullIf(rt.rx_then, 0) * 100, 0),\n     NULL\n  )                                                                               AS \"RX Chg%\",\n  toUnixTimestamp(y.last_seen) * 1000                                              AS \"Last Seen\"\nFROM ytd y\nLEFT JOIN online o ON y.vcasa_name = o.vcasa_name\nLEFT JOIN ping_by_vcasa pg ON y.vcasa_name = pg.vcasa_name\nLEFT JOIN net_by_vcasa nk ON y.vcasa_name = nk.vcasa_name\nLEFT JOIN rx_now_cte rn ON y.vcasa_name = rn.vcasa_name\nLEFT JOIN rx_then_cte rt ON y.vcasa_name = rt.vcasa_name\nORDER BY \"Up %\" DESC",
          "format": 1,
          "refId": "A"
        }
      ]
    }
  ]
}