                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH samples AS (\n  SELECT\n    host,\n    ts,\n    node_network_rx_bytes,\n    node_network_tx_bytes,\n    row_number() OVER (PARTITION BY host ORDER BY ts DESC) AS rn\n  FROM node_exporter_metrics\n  WHERE ts >= now() - INTERVAL 30 MINUTE\n    -- AND host LIKE 'prox%'  -- re-enable if you actually have prox* hosts\n),\nlatest AS (\n  SELECT * FROM samples WHERE rn = 1\n),\nprevious AS (\n  SELECT * FROM samples WHERE rn = 2\n),\ndeltas AS (\n  SELECT\n    latest.host,\n    (latest.node_network_rx_bytes - previous.node_network_rx_bytes) AS rx_diff,\n    (latest.node_network_tx_bytes - previous.node_network_tx_bytes) AS tx_diff\n  FROM latest\n  JOIN previous ON latest.host = previous.host\n  WHERE latest.node_network_rx_bytes >= previous.node_network_rx_bytes\n    AND latest.node_network_tx_bytes >= previous.node_network_tx_bytes\n)\nSELECT\n  if(\n    sum(tx_diff) = 0,\n    0,\n    round(sum(rx_diff) / sum(tx_diff), 2)\n  ) AS aggregate_rx_tx_ratio\nFROM deltas\nWHERE tx_diff > 0;\n",
                    "refId": "B"
                }
            ],
            "title": "Proxmux  Traffic Ratios",
            "type": "gauge"
