                    "pluginVersion": "4.10.0",
                    "queryType": "table",
                    "rawSql": "WITH\n  cutoff AS (\n    SELECT toStartOfHour(now()) - INTERVAL 2 HOUR AS cut\n  ),\n  per_hour AS (\n    SELECT\n      toHour(timestamp) AS hour_of_day,\n      sum(Impressions) AS imps,\n      sum(Requests) AS reqs\n    FROM default.`26_ss_dist_reporting`\n    WHERE timestamp >= (SELECT cut FROM cutoff) - INTERVAL 7 DAY\n      AND timestamp <  (SELECT cut FROM cutoff)\n    GROUP BY hour_of_day\n  ),\n  win_by_hour AS (\n    -- compute weighted wins for each hour (equivalent to impressions)\n    SELECT\n      hour_of_day,\n      reqs * (imps / nullIf(reqs, 0)) AS weighted_win\n    FROM per_hour\n  )\nSELECT\n  hour_of_day,\n  -- only return the normalized share (percentage) for graphing\n  weighted_win / sum(weighted_win) OVER () * 100 AS win_share_pct\nFROM win_by_hour\nORDER BY hour_of_day;\n",
                    "refId": "B"
                }
            ],
